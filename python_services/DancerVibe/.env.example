# 企业微信配置信息
# 将此文件复制为 .env 并填入实际值
# 或者直接在系统环境变量中设置

# 你的企业 ID (在企业微信后台 -> 我的企业 -> 企业信息 中查看)
WECOM_CORP_ID=YOUR_CORP_ID_HERE

# 你的应用 Secret (在企业微信后台 -> 应用管理 -> 自建应用 -> 点击你的应用 中查看)
WECOM_SECRET=YOUR_SECRET_HERE

# 你的应用 AgentID (在企业微信后台 -> 应用管理 -> 自建应用 -> 点击你的应用 中查看)
WECOM_AGENT_ID=YOUR_AGENT_ID_HERE

# 自动生成的 Token (用于回调验证)
WECOM_TOKEN=WdxNxp1D0kH1PFN2

# 自动生成的 EncodingAESKey (用于消息加密)
WECOM_AES_KEY=hMBzfc7sMjrrmzYeWnEa7Vd76uRLyROBhZIvaIM8GNY
