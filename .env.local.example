# Supabase 配置
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ACRCloud 配置（已在 Edge Function 中配置）
# Project ID: 8091
# Account: dancervibe
# Host: identify-cn-north-1.acrcloud.cn

# Phoenix 课表爬虫配置
PHOENIX_ARTICLE_URL=https://mp.weixin.qq.com/s/your-article
PHOENIX_ACCOUNT_HOME_URL=https://mp.weixin.qq.com/mp/profile_ext?action=home&__biz=your_biz
PHOENIX_DATA_DIR=./data/phoenix
PHOENIX_MONTH=2026-02
PHOENIX_XPATH=//*[@id="js_content"]/section[1]/section[16]//img
PHOENIX_IMAGE_INDICES=0,1,2,3
PHOENIX_FALLBACK_URLS=https://example.com/a.png,https://example.com/b.png,https://example.com/c.png,https://example.com/d.png
ENABLE_SCHEDULER=0

# 邮件通知配置
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=your_user
SMTP_PASS=your_pass
EMAIL_FROM=notify@example.com
EMAIL_TO=ops@example.com,admin@example.com
